{
  "name": "inventaire",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "next start",
    "lint": "eslint",
    "seed": "node scripts/seed.mjs",
    "desktop": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "ma.iav.inventaire",
    "productName": "Inventaire IAV",
    "asar": true,
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "output": "desktop-portable"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*",
          "!data/**",
          "!backups/**",
          "!desktop-build/**",
          "!desktop-portable/**",
          "!dist-desktop/**"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
